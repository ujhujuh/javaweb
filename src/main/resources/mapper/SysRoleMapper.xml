<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.javaweb.mapper.SysRoleMapper">

    <delete id="deleteRoleMenuByRoleId">
        DELETE FROM sys_role_menu WHERE role_id = #{roleId}
    </delete>

    <insert id="insertRoleMenu">
        INSERT INTO sys_role_menu (role_id, menu_id) VALUES
        <foreach collection="menuIds" item="menuId" separator=",">
            (#{roleId}, #{menuId})
        </foreach>
    </insert>

    <select id="selectMenuIdsByRoleId" resultType="java.lang.Long">
        SELECT menu_id FROM sys_role_menu WHERE role_id = #{roleId}
    </select>

    <delete id="deleteUserRoleByRoleId">
        DELETE FROM sys_user_role WHERE role_id = #{roleId}
    </delete>

    <insert id="insertUserRoleByRole">
        INSERT INTO sys_user_role (user_id, role_id) VALUES
        <foreach collection="userIds" item="userId" separator=",">
            (#{userId}, #{roleId})
        </foreach>
    </insert>

    <select id="selectUsersByRoleId" resultMap="com.example.javaweb.mapper.SysUserMapper.BaseResultMap">
        SELECT u.* FROM sys_user u
        INNER JOIN sys_user_role ur ON u.id = ur.user_id
        WHERE ur.role_id = #{roleId}
        AND u.del_flag = '0'
    </select>

</mapper>